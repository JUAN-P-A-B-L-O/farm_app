@startuml
top to bottom direction
skinparam packageStyle rectangle
skinparam linetype ortho

actor "Public Client" as Public
actor "Authenticated User" as User
actor "WORKER" as Worker
actor "MANAGER" as Manager

User <|-- Worker
User <|-- Manager

rectangle "Farm Management System" {

  package "Authentication" {
    (Login) as UC_Login
    (Create User) as UC_CreateUser
  }

  package "Farms" {
    (Create Farm) as UC_CreateFarm
    (View Accessible Farms) as UC_ViewFarms
  }

  package "Animals" {
    (Create Animal) as UC_CreateAnimal
    (View Animals) as UC_ViewAnimals
    (Update Animal) as UC_UpdateAnimal
    (Sell Animal) as UC_SellAnimal
    (Soft Delete Animal) as UC_DeleteAnimal
  }

  package "Feed Types" {
    (Create Feed Type) as UC_CreateFeedType
    (View Feed Types) as UC_ViewFeedTypes
    (Update Feed Type) as UC_UpdateFeedType
    (Soft Delete Feed Type) as UC_DeleteFeedType
  }

  package "Feeding" {
    (Record Feeding) as UC_RecordFeeding
    (View Feeding History) as UC_ViewFeedingHistory
    (Update Feeding) as UC_UpdateFeeding
    (Soft Delete Feeding) as UC_DeleteFeeding
  }

  package "Production" {
    (Record Production) as UC_RecordProduction
    (View Production History) as UC_ViewProductionHistory
    (Update Production) as UC_UpdateProduction
    (Soft Delete Production) as UC_DeleteProduction
    (View Production Summary) as UC_ViewProductionSummary
  }

  package "Milk Prices" {
    (Register Milk Price) as UC_RegisterMilkPrice
    (View Current Milk Price) as UC_ViewCurrentMilkPrice
    (View Milk Price History) as UC_ViewMilkPriceHistory
  }

  package "Reporting - MANAGER only" {
    (View Dashboard) as UC_ViewDashboard
    (View Analytics) as UC_ViewAnalytics
  }
}

Public --> UC_Login
Public --> UC_CreateUser

User --> UC_CreateFarm
User --> UC_ViewFarms
User --> UC_CreateAnimal
User --> UC_ViewAnimals
User --> UC_UpdateAnimal
User --> UC_SellAnimal
User --> UC_CreateFeedType
User --> UC_ViewFeedTypes
User --> UC_UpdateFeedType
User --> UC_RecordFeeding
User --> UC_ViewFeedingHistory
User --> UC_UpdateFeeding
User --> UC_RecordProduction
User --> UC_ViewProductionHistory
User --> UC_UpdateProduction
User --> UC_ViewProductionSummary
User --> UC_RegisterMilkPrice
User --> UC_ViewCurrentMilkPrice
User --> UC_ViewMilkPriceHistory

Manager --> UC_DeleteAnimal
Manager --> UC_DeleteFeedType
Manager --> UC_DeleteFeeding
Manager --> UC_DeleteProduction
Manager --> UC_ViewDashboard
Manager --> UC_ViewAnalytics

note right of Manager
  MANAGER is required for:
  - dashboard
  - analytics
  - delete operations
end note

UC_ViewAnalytics .> UC_ViewProductionHistory : <<uses>>
UC_ViewDashboard .> UC_ViewProductionSummary : <<uses>>

@enduml
