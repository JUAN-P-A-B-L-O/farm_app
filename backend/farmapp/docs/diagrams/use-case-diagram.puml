@startuml
top to bottom direction
skinparam packageStyle rectangle
skinparam linetype ortho

actor "Farm Manager" as Manager
actor "Farm Worker" as Worker

rectangle "Farm Management System" {

  package "Animals" {
    (View Animals) as UC_ViewAnimals
    (Manage Animals) as UC_ManageAnimals
    (View Animal Details) as UC_ViewAnimalDetails
  }

  package "Production" {
    (Record Production) as UC_RecordProduction
    (View Production History) as UC_ViewProductionHistory
  }

  package "Feeding" {
    (Record Feeding) as UC_RecordFeeding
    (View Feeding History) as UC_ViewFeedingHistory
  }

  package "Feed Types" {
    (Manage Feed Types) as UC_ManageFeedTypes
    (View Feed Types) as UC_ViewFeedTypes
  }

  package "Users" {
    (Manage Users) as UC_ManageUsers
  }

  package "Analytics" {
    (View Dashboard) as UC_ViewDashboard
    (View Analytics) as UC_ViewAnalytics
  }

  package "System" {
    (Switch Language) as UC_SwitchLanguage
  }
}

' -------- Manager --------
Manager --> UC_ManageAnimals
Manager --> UC_ViewAnimals
Manager --> UC_ViewAnimalDetails
Manager --> UC_RecordProduction
Manager --> UC_RecordFeeding
Manager --> UC_ManageFeedTypes
Manager --> UC_ManageUsers
Manager --> UC_ViewDashboard
Manager --> UC_ViewAnalytics
Manager --> UC_SwitchLanguage

' -------- Worker --------
Worker --> UC_ViewAnimals
Worker --> UC_ViewAnimalDetails
Worker --> UC_RecordProduction
Worker --> UC_RecordFeeding
Worker --> UC_ViewFeedTypes
Worker --> UC_ViewDashboard
Worker --> UC_ViewAnalytics
Worker --> UC_SwitchLanguage

' -------- Includes --------
UC_ViewAnimalDetails .> UC_ViewProductionHistory : <<include>>
UC_ViewAnimalDetails .> UC_ViewFeedingHistory : <<include>>

@enduml