@startuml
title Farm App Backend - Component Diagram

top to bottom direction
skinparam componentStyle rectangle
skinparam packageStyle rectangle
skinparam linetype ortho
skinparam shadowing false

actor Client as "API Client"

package "Security" {
  [SecurityConfig]
  [JwtAuthenticationFilter]
  [AuthService]
  [AuthenticationContextService]
}

package "API Layer" {
  [AuthController]
  [FarmController]
  [AnimalController]
  [FeedTypeController]
  [FeedingController]
  [ProductionController]
  [MilkPriceController]
  [DashboardController]
  [AnalyticsController]
  [UserController]
}

package "Service Layer" {
  [FarmAccessService]
  [FarmService]
  [AnimalService]
  [FeedTypeService]
  [FeedingService]
  [ProductionService]
  [MilkPriceService]
  [DashboardService]
  [AnalyticsService]
  [UserService]
  [Mapper Components]
}

package "Repository Layer" {
  [FarmRepository]
  [AnimalRepository]
  [FeedTypeRepository]
  [FeedingRepository]
  [ProductionRepository]
  [MilkPriceRepository]
  [UserRepository]
}

database "Database" as Database

Client --> [AuthController]
Client --> [JwtAuthenticationFilter]
[JwtAuthenticationFilter] --> [AuthenticationContextService]
[AuthController] --> [AuthService]
[AuthService] --> [UserRepository]

Client --> [FarmController]
Client --> [AnimalController]
Client --> [FeedTypeController]
Client --> [FeedingController]
Client --> [ProductionController]
Client --> [MilkPriceController]
Client --> [DashboardController]
Client --> [AnalyticsController]
Client --> [UserController]

[FarmController] --> [FarmService]
[AnimalController] --> [AnimalService]
[FeedTypeController] --> [FeedTypeService]
[FeedingController] --> [FeedingService]
[ProductionController] --> [ProductionService]
[MilkPriceController] --> [MilkPriceService]
[DashboardController] --> [DashboardService]
[AnalyticsController] --> [AnalyticsService]
[UserController] --> [UserService]

[FarmService] --> [AuthenticationContextService]
[FarmService] --> [FarmRepository]

[FarmAccessService] --> [AuthenticationContextService]
[FarmAccessService] --> [FarmRepository]

[AnimalService] --> [FarmAccessService]
[AnimalService] --> [AnimalRepository]
[AnimalService] --> [Mapper Components]

[FeedTypeService] --> [FarmAccessService]
[FeedTypeService] --> [FeedTypeRepository]
[FeedTypeService] --> [Mapper Components]

[FeedingService] --> [FarmAccessService]
[FeedingService] --> [AuthenticationContextService]
[FeedingService] --> [FeedingRepository]
[FeedingService] --> [AnimalRepository]
[FeedingService] --> [FeedTypeRepository]
[FeedingService] --> [UserRepository]
[FeedingService] --> [Mapper Components]

[ProductionService] --> [FarmAccessService]
[ProductionService] --> [AuthenticationContextService]
[ProductionService] --> [ProductionRepository]
[ProductionService] --> [FeedingRepository]
[ProductionService] --> [AnimalRepository]
[ProductionService] --> [UserRepository]
[ProductionService] --> [MilkPriceService]
[ProductionService] --> [Mapper Components]

[MilkPriceService] --> [FarmAccessService]
[MilkPriceService] --> [AuthenticationContextService]
[MilkPriceService] --> [MilkPriceRepository]
[MilkPriceService] --> [FarmRepository]

[DashboardService] --> [FarmAccessService]
[DashboardService] --> [ProductionRepository]
[DashboardService] --> [FeedingRepository]
[DashboardService] --> [AnimalRepository]
[DashboardService] --> [MilkPriceService]

[AnalyticsService] --> [FarmAccessService]
