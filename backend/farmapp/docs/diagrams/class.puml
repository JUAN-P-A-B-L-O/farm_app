@startuml
title Farm App Backend - Class Diagram

top to bottom direction
skinparam packageStyle rectangle
skinparam linetype ortho
skinparam shadowing false
skinparam classAttributeIconSize 0
hide empty members

package "Controller Layer" {
  class AnimalController <<Controller>> {
    - animalService: AnimalService
    + create(request: CreateAnimalRequest): ResponseEntity<AnimalResponse>
    + findAll(farmId: String): ResponseEntity<List<AnimalResponse>>
    + findById(id: String): ResponseEntity<AnimalResponse>
    + update(id: String, request: UpdateAnimalRequest): ResponseEntity<AnimalResponse>
    + delete(id: String): ResponseEntity<Void>
  }

  class ProductionController <<Controller>> {
    - productionService: ProductionService
    + findAll(animalId: String, date: LocalDate): ResponseEntity<List<ProductionResponse>>
    + findById(id: String): ResponseEntity<ProductionResponse>
    + getSummaryByAnimal(animalId: String): ResponseEntity<ProductionSummaryResponse>
    + getProfit(animalId: String): ResponseEntity<ProductionProfitResponse>
    + create(request: CreateProductionRequest): ResponseEntity<ProductionResponse>
    + update(id: String, request: UpdateProductionRequest): ResponseEntity<ProductionResponse>
  }

  class FeedingController <<Controller>> {
    - feedingService: FeedingService
    + create(request: CreateFeedingRequest): ResponseEntity<FeedingResponse>
    + findAll(): ResponseEntity<List<FeedingResponse>>
    + findById(id: String): ResponseEntity<FeedingResponse>
  }

  class FeedTypeController <<Controller>> {
    - feedTypeService: FeedTypeService
    + create(request: CreateFeedTypeRequest): ResponseEntity<FeedTypeResponse>
    + findAll(): ResponseEntity<List<FeedTypeResponse>>
    + findById(id: String): ResponseEntity<FeedTypeResponse>
  }

  class UserController <<Controller>> {
    - userService: UserService
    + create(request: CreateUserRequest): ResponseEntity<UserResponse>
    + findAll(): ResponseEntity<List<UserResponse>>
    + findById(id: String): ResponseEntity<UserResponse>
  }

  class DashboardController <<Controller>> {
    - dashboardService: DashboardService
    + getDashboard(): ResponseEntity<DashboardResponse>
  }
}

package "Service Layer" {
  class AnimalService <<Service>> {
    - animalRepository: AnimalRepository
    - animalMapper: AnimalMapper
    + create(request: CreateAnimalRequest): AnimalResponse
    + findAll(farmId: String): List<AnimalResponse>
    + findById(id: String): AnimalResponse
    + update(id: String, request: UpdateAnimalRequest): AnimalResponse
    + delete(id: String): void
    - validateInput(request: CreateAnimalRequest): void
    - applyUpdates(entity: AnimalEntity, request: UpdateAnimalRequest): void
  }

  class ProductionService <<Service>> {
    - productionRepository: ProductionRepository
    - feedingRepository: FeedingRepository
    - animalRepository: AnimalRepository
    - userRepository: UserRepository
    - productionMapper: ProductionMapper
    - MILK_PRICE: Double
    + create(request: CreateProductionRequest): ProductionResponse
    + findAll(animalId: String, date: LocalDate): List<ProductionResponse>
    + findById(id: String): ProductionResponse
    + getSummaryByAnimal(animalId: String): ProductionSummaryResponse
    + getProfitByAnimal(animalId: String): ProductionProfitResponse
    + update(id: String, request: UpdateProductionRequest): ProductionResponse
    - validateInput(request: CreateProductionRequest): void
    - findProductions(animalId: String, date: LocalDate): List<ProductionEntity>
  }

  class FeedingService <<Service>> {
    - feedingRepository: FeedingRepository
    - animalRepository: AnimalRepository
    - feedTypeRepository: FeedTypeRepository
    - userRepository: UserRepository
    - feedingMapper: FeedingMapper
    + create(request: CreateFeedingRequest): FeedingResponse
    + findAll(): List<FeedingResponse>
    + findById(id: String): FeedingResponse
    - validateInput(request: CreateFeedingRequest): void
    - validateRelations(request: CreateFeedingRequest): void
  }

  class FeedTypeService <<Service>> {
    - feedTypeRepository: FeedTypeRepository
    - feedTypeMapper: FeedTypeMapper
    + create(request: CreateFeedTypeRequest): FeedTypeResponse
    + findAll(): List<FeedTypeResponse>
    + findById(id: String): FeedTypeResponse
    - validateInput(request: CreateFeedTypeRequest): void
  }

  class UserService <<Service>> {
    - userRepository: UserRepository
    - userMapper: UserMapper
    + create(request: CreateUserRequest): UserResponse
    + findAll(): List<UserResponse>
    + findById(id: String): UserResponse
    - validateInput(request: CreateUserRequest): void
  }

  class DashboardService <<Service>> {
    - productionRepository: ProductionRepository
    - feedingRepository: FeedingRepository
    - animalRepository: AnimalRepository
    - MILK_PRICE: Double
    + getDashboard(): DashboardResponse
    - defaultToZero(value: Double): Double
  }

  class AnimalMapper <<Mapper>> {
    + toEntity(request: CreateAnimalRequest): AnimalEntity
    + toResponse(entity: AnimalEntity): AnimalResponse
  }

  class ProductionMapper <<Mapper>> {
    + toEntity(request: CreateProductionRequest): ProductionEntity
    + toResponse(entity: ProductionEntity): ProductionResponse
  }

  class FeedingMapper <<Mapper>> {
    + toEntity(request: CreateFeedingRequest): FeedingEntity
    + toResponse(entity: FeedingEntity): FeedingResponse
  }

  class FeedTypeMapper <<Mapper>> {
    + toEntity(request: CreateFeedTypeRequest): FeedTypeEntity
    + toResponse(entity: FeedTypeEntity): FeedTypeResponse
  }

  class UserMapper <<Mapper>> {
    + toEntity(request: CreateUserRequest): UserEntity
    + toResponse(entity: UserEntity): UserResponse
  }
}

package "Repository Layer" {
  interface AnimalRepository <<Repository>> {
    + findById(id: String): Optional<AnimalEntity>
    + findAll(): List<AnimalEntity>
    + findByFarmId(farmId: String): List<AnimalEntity>
    + save(entity: AnimalEntity): AnimalEntity
    + deleteById(id: String): void
    + existsById(id: String): boolean
    + count(): Long
  }

  interface ProductionRepository <<Repository>> {
    + findById(id: String): Optional<ProductionEntity>
    + findAll(): List<ProductionEntity>
    + findByAnimalId(animalId: String): List<ProductionEntity>
    + findByDate(date: LocalDate): List<ProductionEntity>
    + findByAnimalIdAndDate(animalId: String, date: LocalDate): List<ProductionEntity>
    + save(entity: ProductionEntity): ProductionEntity
    + sumQuantityByAnimalId(animalId: String): Double
    + sumProductionByAnimalId(animalId: String): Double
    + sumTotalProduction(): Double
  }

  interface FeedingRepository <<Repository>> {
    + findById(id: String): Optional<FeedingEntity>
    + findAll(): List<FeedingEntity>
    + save(entity: FeedingEntity): FeedingEntity
    + sumFeedingCostByAnimalId(animalId: String): Double
    + sumTotalFeedingCost(): Double
  }

  interface FeedTypeRepository <<Repository>> {
    + findById(id: String): Optional<FeedTypeEntity>
    + findAll(): List<FeedTypeEntity>
    + save(entity: FeedTypeEntity): FeedTypeEntity
    + existsById(id: String): boolean
  }

  interface UserRepository <<Repository>> {
    + findById(id: UUID): Optional<UserEntity>
    + findAll(): List<UserEntity>
    + save(entity: UserEntity): UserEntity
    + existsById(id: UUID): boolean
  }
}

package "Domain Layer" {
  class AnimalEntity <<Entity>> {
    + id: String
    + tag: String
    + breed: String
    + birthDate: LocalDate
    + status: String
    + farmId: String
  }

  class ProductionEntity <<Entity>> {
    + id: String
    + animalId: String
    + date: LocalDate
    + quantity: Double
    + createdBy: String
  }

  class FeedingEntity <<Entity>> {
    + id: String
    + animalId: String
    + feedTypeId: String
    + date: LocalDate
    + quantity: Double
    + createdBy: String
  }

  class FeedTypeEntity <<Entity>> {
    + id: String
    + name: String
    + costPerKg: Double
    + active: Boolean
  }

  class UserEntity <<Entity>> {
    + id: UUID
    + name: String
    + email: String
    + role: String
  }
}

package "DTO Layer" {
  class CreateAnimalRequest <<RequestDTO>> {
    + tag: String
    + breed: String
    + birthDate: LocalDate
    + farmId: String
  }

  class UpdateAnimalRequest <<RequestDTO>> {
    + tag: String
    + breed: String
    + birthDate: LocalDate
    + status: String
    + farmId: String
    + isTagValid(): boolean
    + isBreedValid(): boolean
    + isStatusValid(): boolean
    + isFarmIdValid(): boolean
  }

  class AnimalResponse <<ResponseDTO>> {
    + id: String
    + tag: String
    + breed: String
    + birthDate: LocalDate
    + status: String
    + farmId: String
  }

  class CreateProductionRequest <<RequestDTO>> {
    + animalId: String
    + date: LocalDate
    + quantity: Double
    + userId: String
  }

  class UpdateProductionRequest <<RequestDTO>> {
    + date: LocalDate
    + quantity: Double
  }

  class ProductionResponse <<ResponseDTO>> {
    + id: String
    + animalId: String
    + date: LocalDate
    + quantity: Double
  }

  class ProductionSummaryResponse <<ResponseDTO>> {
    + animalId: String
    + totalQuantity: Double
  }

  class ProductionProfitResponse <<ResponseDTO>> {
    + animalId: String
    + totalProduction: Double
    + totalFeedingCost: Double
    + milkPrice: Double
    + revenue: Double
    + profit: Double
  }

  class CreateFeedingRequest <<RequestDTO>> {
    + animalId: String
    + feedTypeId: String
    + date: LocalDate
    + quantity: Double
    + userId: String
  }

  class FeedingResponse <<ResponseDTO>> {
    + id: String
    + animalId: String
    + feedTypeId: String
    + date: LocalDate
    + quantity: Double
  }

  class CreateFeedTypeRequest <<RequestDTO>> {
    + name: String
    + costPerKg: Double
  }

  class FeedTypeResponse <<ResponseDTO>> {
    + id: String
    + name: String
    + costPerKg: Double
    + active: Boolean
  }

  class CreateUserRequest <<RequestDTO>> {
    + name: String
    + email: String
    + role: String
  }

  class UserResponse <<ResponseDTO>> {
    + id: UUID
    + name: String
    + email: String
    + role: String
  }

  class DashboardResponse <<ResponseDTO>> {
    + totalProduction: Double
    + totalFeedingCost: Double
    + totalRevenue: Double
    + totalProfit: Double
    + animalCount: Long
  }
}

