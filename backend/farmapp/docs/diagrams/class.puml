@startuml
title Farm App Backend - Class Diagram

top to bottom direction
skinparam packageStyle rectangle
skinparam linetype ortho
skinparam shadowing false
skinparam classAttributeIconSize 0
hide empty members

package "Controller Layer" {
  class AuthController <<Controller>> {
    + login(request: LoginRequest): ResponseEntity<LoginResponse>
  }

  class FarmController <<Controller>> {
    + findAll(): ResponseEntity<List<FarmResponse>>
    + create(request: CreateFarmRequest): ResponseEntity<FarmResponse>
  }

  class AnimalController <<Controller>> {
    + create(request: CreateAnimalRequest): ResponseEntity<AnimalResponse>
    + findAll(farmId: String): ResponseEntity<List<AnimalResponse>>
    + findById(id: String, farmId: String): ResponseEntity<AnimalResponse>
    + update(id: String, request: UpdateAnimalRequest, farmId: String): ResponseEntity<AnimalResponse>
    + sell(id: String, request: SellAnimalRequest, farmId: String): ResponseEntity<AnimalResponse>
    + delete(id: String, farmId: String): ResponseEntity<Void>
  }

  class FeedTypeController <<Controller>> {
    + create(request: CreateFeedTypeRequest, farmId: String): ResponseEntity<FeedTypeResponse>
    + findAll(farmId: String): ResponseEntity<List<FeedTypeResponse>>
    + findById(id: String, farmId: String): ResponseEntity<FeedTypeResponse>
    + update(id: String, request: CreateFeedTypeRequest, farmId: String): ResponseEntity<FeedTypeResponse>
    + delete(id: String, farmId: String): ResponseEntity<Void>
  }

  class FeedingController <<Controller>> {
    + create(request: CreateFeedingRequest, farmId: String): ResponseEntity<FeedingResponse>
    + findAll(animalId: String, date: LocalDate, farmId: String, page: Integer, size: Integer): ResponseEntity<?>
    + findById(id: String, farmId: String): ResponseEntity<FeedingResponse>
    + update(id: String, request: UpdateFeedingRequest, farmId: String): ResponseEntity<FeedingResponse>
    + delete(id: String, farmId: String): ResponseEntity<Void>
  }

  class ProductionController <<Controller>> {
    + findAll(animalId: String, date: LocalDate, farmId: String, page: Integer, size: Integer): ResponseEntity<?>
    + findById(id: String, farmId: String): ResponseEntity<ProductionResponse>
    + getSummaryByAnimal(animalId: String, farmId: String): ResponseEntity<ProductionSummaryResponse>
    + getProfit(animalId: String, farmId: String, includeAcquisitionCost: boolean): ResponseEntity<ProductionProfitResponse>
    + create(request: CreateProductionRequest, farmId: String): ResponseEntity<ProductionResponse>
    + update(id: String, request: UpdateProductionRequest, farmId: String): ResponseEntity<ProductionResponse>
    + delete(id: String, farmId: String): ResponseEntity<Void>
  }

  class MilkPriceController <<Controller>> {
    + create(request: CreateMilkPriceRequest, farmId: String): ResponseEntity<MilkPriceResponse>
    + getCurrent(farmId: String): ResponseEntity<MilkPriceResponse>
    + getHistory(farmId: String): ResponseEntity<List<MilkPriceResponse>>
  }

  class DashboardController <<Controller>> {
    + getDashboard(farmId: String, includeAcquisitionCost: boolean): ResponseEntity<DashboardResponse>
  }

  class AnalyticsController <<Controller>> {
    + getProductionAnalytics(startDate: LocalDate, endDate: LocalDate, animalId: String, farmId: String, groupBy: String): ResponseEntity<List<AnalyticsTimeSeriesPointResponse>>
    + getFeedingAnalytics(startDate: LocalDate, endDate: LocalDate, animalId: String, farmId: String, groupBy: String): ResponseEntity<List<AnalyticsTimeSeriesPointResponse>>
    + getProfitAnalytics(startDate: LocalDate, endDate: LocalDate, animalId: String, farmId: String, includeAcquisitionCost: boolean, groupBy: String): ResponseEntity<List<AnalyticsProfitPointResponse>>
    + getProductionByAnimal(startDate: LocalDate, endDate: LocalDate, animalId: String, farmId: String): ResponseEntity<List<AnalyticsAnimalProductionPointResponse>>
  }

  class UserController <<Controller>> {
    + create(request: CreateUserRequest): ResponseEntity<UserResponse>
    + findAll(): ResponseEntity<List<UserResponse>>
    + findById(id: String): ResponseEntity<UserResponse>
  }
}

package "Service Layer" {
  class FarmAccessService <<Service>>
  class AuthenticationContextService <<Service>>
  class FarmService <<Service>>
  class AnimalService <<Service>>
  class FeedTypeService <<Service>>
  class FeedingService <<Service>>
  class ProductionService <<Service>>
  class MilkPriceService <<Service>>
  class DashboardService <<Service>>
  class AnalyticsService <<Service>>
  class UserService <<Service>>
  class AuthService <<Service>>
}

package "Repository Layer" {
  interface FarmRepository <<Repository>>
  interface AnimalRepository <<Repository>>
  interface FeedTypeRepository <<Repository>>
  interface FeedingRepository <<Repository>>
  interface ProductionRepository <<Repository>>
  interface MilkPriceRepository <<Repository>>
  interface UserRepository <<Repository>>
}

package "Entity Layer" {
  class UserEntity <<Entity>> {
    + id: UUID
    + name: String
    + email: String
    + role: String
    + password: String
  }

  class FarmEntity <<Entity>> {
    + id: String
    + name: String
    + ownerId: UUID
  }

  class AnimalEntity <<Entity>> {
    + id: String
    + tag: String
    + breed: String
    + birthDate: LocalDate
    + status: String
    + origin: String
    + acquisitionCost: Double
    + salePrice: Double
    + saleDate: LocalDate
    + farmId: String
  }

  class FeedTypeEntity <<Entity>> {
    + id: String
    + name: String
    + costPerKg: Double
    + active: Boolean
    + farmId: String
  }

  class FeedingEntity <<Entity>> {
    + id: String
    + animalId: String
    + feedTypeId: String
    + date: LocalDate
    + quantity: Double
    + createdBy: String
    + farmId: String
    + status: String
  }

  class ProductionEntity <<Entity>> {
    + id: String
    + animalId: String
    + date: LocalDate
    + quantity: Double
    + createdBy: String
    + farmId: String
    + status: String
  }

  class MilkPriceEntity <<Entity>> {
    + id: String
    + farmId: String
    + price: Double
    + effectiveDate: LocalDate
    + createdAt: LocalDateTime
    + createdBy: String
  }
}

FarmService --> FarmRepository
AnimalService --> AnimalRepository
AnimalService --> FarmAccessService
FeedTypeService --> FeedTypeRepository
FeedTypeService --> FarmAccessService
FeedingService --> FeedingRepository
FeedingService --> AnimalRepository
FeedingService --> FeedTypeRepository
FeedingService --> UserRepository
FeedingService --> FarmAccessService
ProductionService --> ProductionRepository
ProductionService --> FeedingRepository
ProductionService --> AnimalRepository
ProductionService --> UserRepository
ProductionService --> MilkPriceService
ProductionService --> FarmAccessService
MilkPriceService --> MilkPriceRepository
MilkPriceService --> FarmRepository
MilkPriceService --> FarmAccessService
DashboardService --> ProductionRepository
DashboardService --> FeedingRepository
DashboardService --> AnimalRepository
DashboardService --> MilkPriceService
AnalyticsService --> ProductionRepository
AnalyticsService --> FeedingRepository
AnalyticsService --> AnimalRepository
AnalyticsService --> FeedTypeRepository
AnalyticsService --> MilkPriceService
UserService --> UserRepository
AuthService --> UserRepository

@enduml
