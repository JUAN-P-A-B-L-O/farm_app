@startuml
title Production Creation Flow

skinparam shadowing false
skinparam sequenceMessageAlign center
skinparam responseMessageBelowArrow true
skinparam ParticipantPadding 25
skinparam BoxPadding 10

actor Client
participant "JwtAuthenticationFilter" as Jwt
participant "ProductionController" as Controller
participant "ProductionService" as Service
participant "AuthenticationContextService" as AuthContext
participant "FarmAccessService" as FarmAccess
participant "AnimalRepository" as AnimalRepo
participant "UserRepository" as UserRepo
participant "ProductionRepository" as ProductionRepo
database "PostgreSQL / Database" as DB
participant "GlobalExceptionHandler" as ErrorHandler

Client -> Jwt: Authorization: Bearer token
Jwt -> Controller: POST /productions\nCreateProductionRequest\noptional farmId
activate Controller

Controller -> Service: create(request, farmId)
activate Service

Service -> AuthContext: resolveUserId(request.userId)
AuthContext --> Service: authenticated user id or fallback userId

Service -> Service: validate request\nanimalId, date, quantity, userId

alt Invalid payload, future date, or invalid UUID
  Service --> ErrorHandler: ValidationException / BusinessException
  ErrorHandler --> Controller: 400 Bad Request\nErrorResponse
  Controller --> Client: 400 Bad Request
else Farm inaccessible
  Service -> FarmAccess: validateAccessibleFarm(farmId or animal.farmId)
  FarmAccess --> Service: ResourceNotFoundException
  Service --> ErrorHandler: propagate exception
  ErrorHandler --> Controller: 404 Not Found\nErrorResponse
  Controller --> Client: 404 Not Found
else Animal not active or not found
  Service -> AnimalRepo: findById / findByIdAndFarmId
  AnimalRepo --> Service: missing or non-ACTIVE animal
  Service --> ErrorHandler: ResourceNotFoundException / ValidationException
  ErrorHandler --> Controller: 404 or 400\nErrorResponse
  Controller --> Client: error response
else User not found
  Service -> UserRepo: existsById(createdBy)
  UserRepo --> Service: false
  Service --> ErrorHandler: ResourceNotFoundException
  ErrorHandler --> Controller: 404 Not Found\nErrorResponse
  Controller --> Client: 404 Not Found
else Valid request
  Service -> ProductionRepo: save(productionEntity ACTIVE)
  activate ProductionRepo
  ProductionRepo -> DB: INSERT productions
  activate DB
  DB --> ProductionRepo: persisted row
  deactivate DB
  ProductionRepo --> Service: saved ProductionEntity
  deactivate ProductionRepo
  Service --> Controller: ProductionResponse
  deactivate Service
  Controller --> Client: 201 Created\nProductionResponse
end

@enduml
