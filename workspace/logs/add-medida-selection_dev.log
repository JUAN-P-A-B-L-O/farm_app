+
+export function convertFeedCostFromBase(value: number, unit: FeedingUnit) {
+  if (!Number.isFinite(value)) {
+    return 0
+  }
+
+  return roundToDisplayPrecision(value * UNIT_FACTORS[unit])
+}
+
