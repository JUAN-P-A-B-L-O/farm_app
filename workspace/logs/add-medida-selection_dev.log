  ],
  "changes": [
    {
      "file": "backend/farmapp/src/main/java/com/jpsoftware/farmapp/feed/controller/FeedTypeController.java",
      "description": "Accepted optional measurementUnit on feed-type CSV export without changing existing default behavior.",
      "code": "@GetMapping(\"/export\")\npublic ResponseEntity<byte[]> export(\n        @RequestParam(required = false) String farmId,\n        @RequestParam(required = false) String search,\n        @RequestParam(required = false) String currency,\n        @RequestParam(required = false) String measurementUnit) {\n    return CsvResponseFactory.buildDownload(\n            \"feed-types.csv\",\n            StringUtils.hasText(measurementUnit)\n                    ? feedTypeService.exportAll(farmId, search, StringUtils.hasText(currency) ? currency : null, measurementUnit)\n                    : feedTypeService.exportAll(farmId, search, StringUtils.hasText(currency) ? currency : null));\n}"
    },
    {
      "file": "backend/farmapp/src/main/java/com/jpsoftware/farmapp/feed/service/FeedTypeService.java",
      "description": "Added unit-aware feed-type CSV export with higher precision for gram-based rates while keeping base costPerKg persistence unchanged.",
      "code": "public String exportAll(String farmId, String search, String currency, String measurementUnitParam) {\n    MeasurementUnit measurementUnit = MeasurementUnit.fromFeedingParam(measurementUnitParam, \"measurementUnit\");\n    int monetaryScale = measurementUnit == MeasurementUnit.GRAM ? FEED_RATE_EXPORT_SCALE : DEFAULT_MONEY_SCALE;\n    List<FeedTypeResponse> rows = findAll(farmId, search).stream()\n            .map(feedType -> new FeedTypeResponse(\n                    feedType.getId(),\n                    feedType.getName(),\n                    CurrencyConversionUtils.convertMonetaryValue(\n                            MeasurementUnitConverter.convertRateFromBase(feedType.getCostPerKg(), measurementUnit, monetaryScale),\n                            currency,\n                            monetaryScale),\n                    feedType.getActive()))\n            .toList();\n\n    if (!StringUtils.hasText(measurementUnitParam)) {\n        return CsvExportUtils.write(rows, List.of(\n                new CsvColumn<>(\"id\", FeedTypeResponse::getId),\n                new CsvColumn<>(\"name\", FeedTypeResponse::getName),\n                new CsvColumn<>(\"costPerKg\", FeedTypeResponse::getCostPerKg),\n                new CsvColumn<>(\"active\", FeedTypeResponse::getActive)));\n    }\n\n    return CsvExportUtils.write(rows, List.of(\n            new CsvColumn<>(\"id\", FeedTypeResponse::getId),\n            new CsvColumn<>(\"name\", FeedTypeResponse::getName),\n            new CsvColumn<>(\"costPerUnit\", FeedTypeResponse::getCostPerKg),\n            new CsvColumn<>(\"costUnit\", row -> measurementUnit.getSymbol()),\n            new CsvColumn<>(\"active\", FeedTypeResponse::getActive)));\n}"
    },
    {
      "file": "backend/farmapp/src/main/java/com/jpsoftware/farmapp/shared/currency/CurrencyConversionUtils.java",
      "description": "Added precision-aware currency conversion overload used by feed-rate exports.",
      "code": "public static Double convertMonetaryValue(Double value, String currencyCode) {\n    return convertMonetaryValue(value, currencyCode, 2);\n}\n\npublic static Double convertMonetaryValue(Double value, String currencyCode, int scale) {\n    if (value == null) {\n        return null;\n    }\n    CurrencyCode currency = CurrencyCode.fromQueryParam(currencyCode);\n    if (currency == CurrencyCode.BRL) {\n        return DecimalScaleUtils.normalize(value, scale);\n    }\n    return DecimalScaleUtils.multiply(value, currency.getConversionRateFromBase(), scale);\n}"
    },
    {
      "file": "backend/farmapp/src/main/java/com/jpsoftware/farmapp/shared/exception/ErrorMessageTranslator.java",
      "description": "Made feed-type validation messages unit-neutral so they stay correct when the UI is using grams.",
      "code": "case \"costPerKg\" -> \"O custo por unidade é obrigatório.\";\ncase \"costPerKg\" -> \"O custo por unidade deve ser maior que zero.\";\ncase \"costPerKg\" -> \"O custo por unidade deve ter no máximo 2 casas decimais.\";"
    },
    {
      "file": "backend/farmapp/src/main/java/com/jpsoftware/farmapp/shared/measurement/MeasurementUnitConverter.java",
      "description": "Added rate conversion support for values stored per base unit and displayed per selected unit.",
      "code": "public static Double convertRateFromBase(Double value, MeasurementUnit unit, int scale) {\n    if (value == null) {\n        return null;\n    }\n    if (unit == MeasurementUnit.GRAM || unit == MeasurementUnit.MILLILITER) {\n        return DecimalScaleUtils.normalize(value / unit.getUnitsPerBaseUnit(), scale);\n    }\n    return DecimalScaleUtils.normalize(value, scale);\n}"
    },
    {
      "file": "backend/farmapp/src/main/java/com/jpsoftware/farmapp/shared/util/DecimalScaleUtils.java",
      "description": "Extended decimal helpers with configurable scale overloads reused by feed-rate conversion/export.",
      "code": "public static Double normalize(Double value) {\n    return normalize(value, SCALE);\n}\n\npublic static Double normalize(Double value, int scale) {\n    return BigDecimal.valueOf(value).setScale(scale, RoundingMode.HALF_UP).doubleValue();\n}\n\npublic static Double multiply(Double left, Double right) {\n    return multiply(left, right, SCALE);\n}\n\npublic static Double multiply(Double left, Double right, int scale) {\n    return BigDecimal.valueOf(left != null ? left : 0.0)\n            .multiply(BigDecimal.valueOf(right != null ? right : 0.0))\n            .setScale(scale, RoundingMode.HALF_UP)\n            .doubleValue();\n}"
    },
    {
      "file": "backend/farmapp/src/test/java/com/jpsoftware/farmapp/contract/feed/FeedTypeControllerContractTest.java",
      "description": "Covered the new measurementUnit export controller path.",
      "code": "@Test\nvoid shouldExportFeedTypesWithMeasurementUnit() throws Exception {\n    feedTypeService.exportResponseWithMeasurementUnit = \"id,name,costPerUnit,costUnit\\nfeed-type-1,Corn Silage,0.00175,g\\n\";\n\n    mockMvc.perform(get(\"/feed-types/export\")\n                    .queryParam(\"farmId\", \"farm-1\")\n                    .queryParam(\"measurementUnit\", \"GRAM\"))\n            .andExpect(status().isOk())\n            .andExpect(content().string(\"id,name,costPerUnit,costUnit\\nfeed-type-1,Corn Silage,0.00175,g\\n\"));\n}"
    },
    {
      "file": "backend/farmapp/src/test/java/com/jpsoftware/farmapp/unit/feed/FeedTypeServiceTest.java",
      "description": "Added unit tests for gram-rate export conversion and invalid measurement-unit rejection.",
      "code": "@Test\nvoid shouldExportFeedTypesWithConvertedMeasurementUnit() {\n    repositoryHandler.store(new FeedTypeEntity(\"feed-type-1\", \"Corn Silage\", 1.75, true, \"farm-1\"));\n\n    String csv = feedTypeService.exportAll(\"farm-1\", null, null, \"GRAM\");\n\n    assertEquals(\"id,name,costPerUnit,costUnit,active\\nfeed-type-1,Corn Silage,0.00175,g,true\\n\", csv);\n}\n\n@Test\nvoid shouldRejectInvalidMeasurementUnitWhenExportingFeedTypes() {\n    ValidationException exception = assertThrows(\n            ValidationException.class,\n            () -> feedTypeService.exportAll(\"farm-1\", null, null, \"LITER\"));\n\n    assertEquals(\"measurementUnit must be KILOGRAM or GRAM\", exception.getMessage());\n}"
    },
    {
      "file": "frontend/web/farm_web/src/components/feed-type/FeedTypeForm.tsx",
      "description": "Converted feed-type cost input to and from the selected feeding unit, added unit-aware validation, and removed the sync effect by remounting on page key changes.",
      "code": "const { currency } = useCurrency()\nconst { feedingUnit } = useMeasurementUnits()\nconst [formData, setFormData] = useState<FeedTypeFormData>(() => initialValues)\n\nconst currentDisplayCost = convertFeedCostFromBase(currentData.costPerKg, feedingUnit)\nconst nextDisplayCost = feedingUnit === 'GRAM'\n  ? value === '' ? 0 : Number.isFinite(Number(value)) ? Number(value) : currentDisplayCost\n  : parseTwoDecimalInput(value, currentDisplayCost)\n\nreturn {\n  ...currentData,\n  costPerKg: convertFeedCostToBase(nextDisplayCost, feedingUnit),\n}\n\nif (!hasAtMostTwoDecimals(formData.costPerKg)) {\n  setValidationMessage(\n    feedingUnit === 'GRAM'\n      ? t('measurementUnits.errors.feedCostStep')\n      : t('feedType.errors.costPrecision'),\n  )\n}\n\nconst costLabel = `${appendCurrencyCode(t('feedType.form.costPerKg'), currency)} / ${unitLabel}`"
    },
    {
