      "file": "frontend/web/farm_web/src/utils/currency.ts",
      "description": "Added precision-aware currency conversion/formatting options so per-gram rates do not collapse to 0.00.",
      "code": "interface CurrencyFormatOptions {\n  minimumFractionDigits?: number\n  maximumFractionDigits?: number\n  conversionPrecision?: number\n}\n\nexport function convertMonetaryValue(value, currency, precision = 2) {\n  return value == null ? null : normalizeMonetaryValue(value * DISPLAY_RATES[currency], precision)\n}\n\nexport function formatDisplayMoney(value, language, currency, options = {}) {\n  const convertedValue = convertMonetaryValue(\n    value,\n    currency,\n    options.conversionPrecision ?? options.maximumFractionDigits ?? 2,\n  )\n  return convertedValue == null ? null : formatCurrencyValue(convertedValue, language, currency, options)\n}"
    },
    {
      "file": "frontend/web/farm_web/src/utils/measurementUnits.ts",
      "description": "Centralized feed-rate conversion helpers and gram-specific input step handling.",
      "code": "const FEED_COST_INPUT_STEPS: Record<FeedingUnit, string> = {\n  KILOGRAM: '0.01',\n  GRAM: '0.00001',\n}\n\nexport function convertFeedCostToBase(value: number, unit: FeedingUnit) {\n  return !Number.isFinite(value) ? 0 : roundToDisplayPrecision(value / UNIT_FACTORS[unit])\n}\n\nexport function convertFeedCostFromBase(value: number, unit: FeedingUnit) {\n  return !Number.isFinite(value) ? 0 : roundToDisplayPrecision(value * UNIT_FACTORS[unit])\n}\n\nexport function getFeedCostInputStep(unit: FeedingUnit) {\n  return FEED_COST_INPUT_STEPS[unit]\n}"
    },
