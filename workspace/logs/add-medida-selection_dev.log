+        if (value == null) {
+            return null;
+        }
+
+        if (unit == MeasurementUnit.GRAM || unit == MeasurementUnit.MILLILITER) {
+            return DecimalScaleUtils.normalize(value / unit.getUnitsPerBaseUnit(), scale);
+        }
+
+        return DecimalScaleUtils.normalize(value, scale);
+    }
 }
