     config.headers.Authorization = `Bearer ${token}`
   }
 
   return config
 })
 
 api.interceptors.response.use(
   (response) => response,
   async (error) => {
     if (shouldHandleUnauthorized(error) && !isHandlingUnauthorized) {
       isHandlingUnauthorized = true
