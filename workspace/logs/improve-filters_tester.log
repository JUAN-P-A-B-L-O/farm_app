diff --git a/frontend/web/farm_web/tests/listing-filters-bar.test.mjs b/frontend/web/farm_web/tests/listing-filters-bar.test.mjs
new file mode 100644
index 0000000000000000000000000000000000000000..583f0b9f62a5223073ca50249b3ab21393ec66f9
--- /dev/null
+++ b/frontend/web/farm_web/tests/listing-filters-bar.test.mjs
@@ -0,0 +1,168 @@
+import assert from 'node:assert/strict'
+import { execFileSync } from 'node:child_process'
+import { mkdirSync, rmSync } from 'node:fs'
+import path from 'node:path'
+import React from 'react'
+import { renderToStaticMarkup } from 'react-dom/server'
+import test from 'node:test'
+import { fileURLToPath, pathToFileURL } from 'node:url'
+
+const __filename = fileURLToPath(import.meta.url)
+const __dirname = path.dirname(__filename)
+const projectRoot = path.resolve(__dirname, '..')
+const sourceRoot = path.join(projectRoot, 'src')
+const compiledRoot = path.join(projectRoot, 'tests', '.compiled-listing-filters')
+
+function compileListingFilterModules() {
+  rmSync(compiledRoot, { force: true, recursive: true })
+  mkdirSync(compiledRoot, { recursive: true })
+
+  execFileSync(
+    'npx',
+    [
+      'tsc',
+      '--outDir',
+      compiledRoot,
+      '--rootDir',
+      sourceRoot,
+      '--module',
+      'NodeNext',
+      '--target',
+      'ES2022',
+      '--jsx',
+      'react-jsx',
+      '--moduleResolution',
+      'NodeNext',
+      '--esModuleInterop',
+      '--skipLibCheck',
+      path.join(sourceRoot, 'components', 'common', 'FilterFields.tsx'),
+      path.join(sourceRoot, 'components', 'common', 'ListingFiltersBar.tsx'),
+    ],
+    {
+      cwd: projectRoot,
+      stdio: 'pipe',
+    },
+  )
+}
+
+function collectElements(node, predicate, result = []) {
+  if (!node) {
+    return result
+  }
+
+  if (Array.isArray(node)) {
+    for (const child of node) {
+      collectElements(child, predicate, result)
+    }
+    return result
+  }
+
+  if (typeof node !== 'object' || !('type' in node) || !('props' in node)) {
+    return result
+  }
+
+  if (predicate(node)) {
+    result.push(node)
+  }
+
+  collectElements(node.props.children, predicate, result)
+  return result
+}
+
+compileListingFilterModules()
+
+const filterFieldsModuleUrl = `${pathToFileURL(path.join(compiledRoot, 'components', 'common', 'FilterFields.js')).href}?t=${Date.now()}`
+const listingFiltersModuleUrl = `${pathToFileURL(path.join(compiledRoot, 'components', 'common', 'ListingFiltersBar.js')).href}?t=${Date.now()}`
+const { CheckboxFilterField, MultiSelectFilterField } = await import(filterFieldsModuleUrl)
+const { default: ListingFiltersBar } = await import(listingFiltersModuleUrl)
+
+test('maps multiselect and checkbox DOM events to typed filter values', () => {
+  let selectedAnimalIds = null
+  let includeAcquisitionCost = null
+
+  const multiselectField = MultiSelectFilterField({
+    id: 'dashboard-animal-select',
+    label: 'Animal',
+    value: [],
+    options: [
+      { value: 'animal-1', label: 'A-101' },
+      { value: 'animal-2', label: 'A-102' },
+    ],
+    onChange: (value) => {
+      selectedAnimalIds = value
+    },
+  })
+  const checkboxField = CheckboxFilterField({
+    id: 'analytics-include-acquisition-cost',
+    label: 'Include acquisition cost in profit',
+    checked: false,
+    onChange: (checked) => {
+      includeAcquisitionCost = checked
+    },
+  })
+
+  const multiselect = collectElements(multiselectField, (element) => element.type === 'select')[0]
+  const checkbox = collectElements(checkboxField, (element) => element.type === 'input')[0]
+
+  multiselect.props.onChange({
+    target: {
+      selectedOptions: [{ value: 'animal-1' }, { value: 'animal-2' }],
+    },
+  })
+  checkbox.props.onChange({
+    target: {
+      checked: true,
+    },
+  })
+
+  assert.deepEqual(selectedAnimalIds, ['animal-1', 'animal-2'])
+  assert.equal(includeAcquisitionCost, true)
+})
+
+test('renders help text, multiselect attributes, and checkbox controls in the shared filters bar', () => {
+  const html = renderToStaticMarkup(
+    React.createElement(ListingFiltersBar, {
+      search: {
+        id: 'animals-search',
+        label: 'Search',
+        value: '',
+        placeholder: 'Search by tag',
+        onChange: () => {},
+      },
+      onApply: () => {},
+      onClear: () => {},
+      applyLabel: 'Apply filters',
+      clearLabel: 'Clear',
+      filters: [
+        {
+          type: 'multiselect',
+          id: 'dashboard-animal-select',
+          label: 'Animal',
+          value: ['animal-2'],
+          options: [
+            { value: 'animal-1', label: 'A-101' },
+            { value: 'animal-2', label: 'A-102' },
+          ],
+          size: 3,
+          helpText: 'Leave empty to include every animal. Multiple selection is supported.',
+          onChange: () => {},
+        },
+        {
+          type: 'checkbox',
+          id: 'dashboard-include-acquisition-cost',
+          label: 'Include acquisition cost in profit',
+          checked: true,
+          onChange: () => {},
+        },
+      ],
+    }),
+  )
+
+  assert.match(html, /type="search"/)
+  assert.match(html, /<select[^>]*id="dashboard-animal-select"[^>]*multiple=""[^>]*size="3"/)
+  assert.match(html, /A-102<\/option>/)
+  assert.match(html, /listing-filters__help">Leave empty to include every animal\. Multiple selection is supported\.<\/small>/)
+  assert.match(html, /type="checkbox"[^>]*checked/)
+  assert.match(html, />Apply filters<\/button>/)
+  assert.match(html, />Clear<\/button>/)
+})
